---
import "./style.css";
import "../assets/stack.svg";
import Servizi from "./Servizi.astro";
---
<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StackHorizon</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="style.css"> <!-- Assicurati che il tuo CSS sia correttamente collegato -->
</head>

<body>

<!-- Navbar -->
<nav class="bg-white py-4">
    <div class="container mx-auto px-8 max-w-7xl">
        <div class="flex items-center">
            <a href="/" class="block">
                <img src='' alt="Logo Aziendale" class="h-10">
            </a>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<div class="container mx-auto pl-10 pr-0 py-12 max-w-7xl">
    <div class="flex flex-col md:flex-row gap-10 items-center">
        <div class="w-full md:w-1/2 space-y-6">
            <div class="space-y-2">
                <h1 class="text-5xl md:text-6xl text-black mb-2">
                    Pensa meno.<br class="mb-4">
                    Sogna di più.
                </h1>
                <h2 class="mt-15 md:text-2xl text-black max-w-lg">
                    StackHorizon aiuta a creare esperienze, idee e sogni, semplificandoli
                </h2>
            </div>

            <button id="iniziaNowBtn" class="mt-8 px-6 py-3 bg-black text-white font-semibold rounded-lg shadow-md hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 hover-pulse">
                Inizia ora il viaggio
            </button>
        </div>

        <div class="w-full md:w-1/2">
        </div>
    </div>
</div>

<!-- Nav Buttons Section -->
<div class="container mx-auto px-8 py-10 max-w-7xl">
    <div class="flex flex-wrap justify-center gap-4 md:gap-6">
        <button data-button="servizi" class="nav-button active clicked-blue flex-1 px-6 py-3 bg-white text-black border-2 border-gray-200 font-medium rounded-lg hover:bg-gray-50 focus:bg-black focus:text-white transition-all duration-300">
            Servizi
        </button>
        <button data-button="progetti" class="nav-button flex-1 px-6 py-3 bg-white text-black border-2 border-gray-200 font-medium rounded-lg hover:bg-gray-50 focus:bg-black focus:text-white transition-all duration-300">
            Progetti
        </button>
        <button data-button="idea" class="nav-button flex-1 px-6 py-3 bg-white text-black border-2 border-gray-200 font-medium rounded-lg hover:bg-gray-50 focus:bg-black focus:text-white transition-all duration-300">
            L'idea
        </button>
        <button data-button="contatti" class="nav-button flex-1 px-6 py-3 bg-white text-black border-2 border-gray-200 font-medium rounded-lg hover:bg-gray-50 focus:bg-black focus:text-white transition-all duration-300">
            Contatti
        </button>
    </div>
</div>

<!-- Servizi Section -->
<div id="servizi" class="content-section hidden">
     <Servizi />
